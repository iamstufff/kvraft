# Copy this file to .env and fill in real values. .env is gitignored.

# Required: Google Gemini API key (free tier is fine for the build)
GEMINI_API_KEY=your-gemini-api-key-here

# Optional (Day 3 stretch)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Cache tuning (sensible defaults — override if experimenting)
SIMILARITY_THRESHOLD=0.85
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HNSW_EF_CONSTRUCTION=200
HNSW_M=16

# Node identity (overridden per-container in docker-compose.yml)
NODE_ID=node1
RAFT_BIND=0.0.0.0:4321
RAFT_PEERS=
